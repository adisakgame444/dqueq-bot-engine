# Database Connection URL (PostgreSQL)
# For local setup, you can run a local PostgreSQL instance or configure a remote database like Neon
DATABASE_URL="postgresql://username:password@localhost:5432/dqueqdb?schema=public"

# Telegram Bot Configurations
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
ADMIN_TELEGRAM_ID="YOUR_TELEGRAM_ADMIN_CHAT_ID"

# Google OAuth API Settings (Optional, used for web login)
GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
GOOGLE_OAUTH_BASE_URL="http://localhost:5000"
GOOGLE_OAUTH_STATE_SECRET="YOUR_RANDOM_STATE_SECRET_KEY"

# Signup Secret Code for Registering Admins on Web
WEB_ADMIN_SIGNUP_CODE="Dqueq999"

# Android Device Setup for Remote Stream
# BlueStacks default port is usually 5555 or 5556
ANDROID_DEVICE="127.0.0.1:5555"

# Path to ADB Executable
# If not set, defaults to "C:\Program Files\BlueStacks_nxt\HD-Adb.exe"
# ADB_PATH="C:\Program Files\BlueStacks_nxt\HD-Adb.exe"
